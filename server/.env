# API Lembaga Eksternal
EXTERNAL_API_URL=http://localhost:3001/mock-api/data
EXTERNAL_API_KEY=dev-mock-key

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://dashboard_user:dashboard_pass@localhost:5433/dashboard_db

# Server
PORT=3001
NODE_ENV=development

# Polling Schedule — every 30 seconds
POLL_CRON=*/30 * * * * *

# Frontend Origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Set to "true" to use built-in mock data generator instead of real API
USE_MOCK_API=true
